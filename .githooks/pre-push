#!/bin/sh
set -eu

die() {
  echo "push blocked: $1" >&2
  exit 1
}

current_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
allowed_branch="main"
allowed_ref="refs/heads/$allowed_branch"

tree_has_path() {
  oid="$1"
  path="$2"
  git cat-file -e "$oid:$path" 2>/dev/null
}

tree_file_has_cyrillic() {
  oid="$1"
  path="$2"
  git show "$oid:$path" | grep -q '[А-Яа-яЁё]'
}

validate_public_surface() {
  oid="$1"

  for path in README.md CONTRIBUTING.md NOTICE LICENSE; do
    if tree_has_path "$oid" "$path" && tree_file_has_cyrillic "$oid" "$path"; then
      die "'$path' must remain English-only in pushed refs."
    fi
  done

  if tree_has_path "$oid" "SPEC.md"; then
    die "root 'SPEC.md' is obsolete; use 'docs/SPEC.md' on non-main branches."
  fi
}

validate_main_tree() {
  oid="$1"

  if git ls-tree -r --name-only "$oid" -- docs | grep -q .; then
    die "'docs/' must not be present in branch 'main'."
  fi
}

while read -r local_ref local_oid remote_ref remote_oid; do
  [ -n "${local_ref:-}" ] || continue

  case "$local_oid" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  case "$remote_ref" in
    refs/heads/*)
      ;;
    *)
      continue
      ;;
  esac

  if [ "$local_ref" != "$allowed_ref" ] || [ "$remote_ref" != "$allowed_ref" ]; then
    die "only '$allowed_branch' may be pushed to the remote repository (attempted: $local_ref -> $remote_ref)."
  fi

  if [ "$current_branch" != "$allowed_branch" ]; then
    die "current branch is '$current_branch'; switch to '$allowed_branch' before pushing."
  fi

  validate_public_surface "$local_oid"
  validate_main_tree "$local_oid"
done

exit 0
